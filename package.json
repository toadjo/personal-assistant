{
  "name": "personal-assistant",
  "version": "1.2.1",
  "description": "Windows tray personal assistant MVP",
  "main": "dist/main/main/main.js",
  "author": "toadjo",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on tcp:5173 file:dist/main/main/main.js file:dist/main/main/preload.js && electron .\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "icons:prepare": "node scripts/ensure-win-icon.mjs",
    "dist": "npm run build && npm run icons:prepare && electron-builder",
    "release:build": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\release-package.ps1",
    "release:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\release-clean.ps1",
    "release:clean:all": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\release-clean.ps1 -All -ConfirmAll",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "lint": "eslint . --no-warn-ignored",
    "lint:fix": "eslint . --fix --no-warn-ignored",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-check.mjs"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,cjs}": "eslint --max-warnings=0 --no-warn-ignored",
    "*.{json,css,html,md,yml,yaml}": "prettier --check"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-log": "^5.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.20.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  },
  "build": {
    "appId": "com.toadjo.personalassistant",
    "productName": "PersonalAssistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "installerIcon": "assets/app-icon.ico",
      "uninstallerIcon": "assets/app-icon.ico"
    }
  }
}
